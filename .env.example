# Default: same-origin subpath proxy at /demo/fms/api/upload (Vite dev + Vercel).
# Leave unset to use withBasePath("/api/upload") automatically.
# VITE_UPLOAD_API_URL=/demo/fms/api/upload

# Direct API (only after API Gateway OPTIONS and CORS is configured):
# VITE_UPLOAD_API_URL=https://yz1zrecbsj.execute-api.ap-southeast-1.amazonaws.com/dev/RnD/webapp/file/upload

# List bucket files (default: /demo/fms/api/files via proxy GET .../file/list)
# VITE_LIST_FILES_API_URL=/demo/fms/api/files
# VITE_LIST_FILES_API_URL=https://yz1zrecbsj.execute-api.ap-southeast-1.amazonaws.com/dev/RnD/webapp/file/list

VITE_MAX_UPLOAD_BYTES=104857600
VITE_UPLOAD_CONCURRENCY=3
